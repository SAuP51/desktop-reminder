{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reminder Settings",
  "version": "0.1.0",
  "identifier": "com.soma-team.reminder.settings",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Reminder Settings",
        "width": 1040,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
